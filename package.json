{
  "name": "zy-board-game-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "smoke:reconnect": "node scripts/smoke-socket-reconnect.mjs",
    "smoke:local-flow": "node scripts/smoke-local-game-flow.mjs",
    "smoke:reactions": "node scripts/smoke-game-reactions.mjs",
    "smoke:result-applause": "node scripts/smoke-result-applause.mjs",
    "smoke:restart": "node scripts/smoke-server-restart-recovery.mjs",
    "verify:art": "node scripts/verify-art-assets.mjs",
    "verify:audio": "node scripts/verify-audio-integration.mjs",
    "verify:quick": "node scripts/run-regression.mjs",
    "verify:release": "node scripts/run-regression.mjs --release"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.6.3"
  }
}
